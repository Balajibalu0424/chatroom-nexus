# Supabase Configuration (from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (for server-side operations - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin control plane
ADMIN_USERNAME=admin
# Generate with: npm run admin:hash-password -- "your-strong-password"
ADMIN_PASSWORD_SCRYPT=scrypt$16384$8$1$replace_salt$replace_hash
# Generate with: npm run admin:totp-secret
ADMIN_TOTP_SECRET=REPLACE_WITH_BASE32_TOTP_SECRET
ADMIN_SESSION_SECRET=replace_with_a_long_random_session_secret

# Upstash Redis for admin login rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# MeshCentral integration
MESHCENTRAL_URL=https://mesh.example.com/
MESHCENTRAL_USERID=user//integration-admin
MESHCENTRAL_LOGIN_TOKEN_KEY=replace_with_meshcentral_login_token_key_hex

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
